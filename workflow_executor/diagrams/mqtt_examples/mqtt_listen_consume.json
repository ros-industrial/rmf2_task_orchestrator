{
  "$schema": "https://raw.githubusercontent.com/open-rmf/crossflow/refs/heads/main/diagram.schema.json",
  "version": "0.1.0",
  "templates": {},
  "start": "fork",
  "ops": {
    "pub_result": {
      "type": "fork_result",
      "ok": {
        "builtin": "dispose"
      },
      "err": {
        "builtin": "dispose"
      }
    },
    "publish": {
      "type": "node",
      "builder": "mqtt_publish",
      "config": {
        "topic": "asset/Robot1/status",
        "payload": {
          "status": "COMPLETED",
          "asset_id": "Robot1"
        },
        "qos": 0,
        "retain": false
      },
      "next": "pub_result"
    },
    "status_result": {
      "type": "fork_result",
      "ok": {
        "builtin": "terminate"
      },
      "err": {
        "builtin": "dispose"
      }
    },
    "check_status": {
      "type": "node",
      "builder": "cel_condition",
      "config": {
        "condition": "status == 'COMPLETED'"
      },
      "next": "status_result"
    },
    "consume": {
      "type": "node",
      "builder": "consume_message",
      "next": "check_status"
    },
    "watch": {
      "type": "listen",
      "buffers": {
        "message": "msg_buffer"
      },
      "next": "consume"
    },
    "msg_buffer": {
      "type": "buffer"
    },
    "mqtt_listen": {
      "type": "node",
      "builder": "mqtt_listen",
      "config": {
        "topic": "asset/Robot1/status",
        "qos": 0
      },
      "next": {
        "builtin": "dispose"
      },
      "stream_out": {
        "message": "msg_buffer"
      }
    },
    "fork": {
      "type": "fork_clone",
      "next": [
        "mqtt_listen",
        "publish"
      ]
    }
  },
  "description": "Showcases the MqttListen + ConsumeMessage pattern.\n\nTwo parallel branches:\n1. MqttListen continuously streams messages from 'asset/Robot1/status' into a buffer. Listen node watches the buffer and triggers ConsumeMessage to read each message. A CEL condition checks if status == 'COMPLETED' and terminates the workflow when matched.\n2. MqttPublish sends a test message with status 'COMPLETED' to the same topic.\n\nDiagram flow: stream_out -> buffer -> listen -> ConsumeMessage -> CELCondition ",
  "input_examples": [
    {
      "name": "Start",
      "description": "Trigger to start listening and publishing",
      "value": {}
    }
  ],
